      <TableDataSource Name="Table" DataType="System.Int32" Enabled="true" SelectCommand="SELECT C.strCompanyName, M.strSurName, M.strOtherName, L.MemberNo, L.LoanNo, L.AppliedAmount, L.LoanBalance, L.ApplicationDate, L.RepaymentPeriod, L.InterestRate, L.RepaymentMethod, L.LoanCode, L.CompanyCode, L.status, L.ApprovedAmount, L.RecommendedAmount, L.PrincipalRepayment, L.InterestRepayment, L.TotalAmount, L.DateApproved, L.DisburseAmount, L.LastRepayDate, L.PaymentMode, L.DisburseDate&#13;&#10;FROM ((&quot;co_Operatives&quot; C INNER JOIN &quot;MembersRegistrations&quot; M ON C.strCompanyCode = M.strCompanyCode &#13;&#10;) INNER JOIN &quot;loanAplications&quot; L ON M.strCompanyCode = L.CompanyCode and  M.strMemberNo = L.MemberNo)">
