        <Column Name="CompanyCode" DataType="System.String"/>
        <Column Name="status" DataType="System.Int32"/>
        <Column Name="ApprovedAmount" DataType="System.Decimal"/>
        <Column Name="RecommendedAmount" DataType="System.Decimal"/>
        <Column Name="PrincipalRepayment" DataType="System.Decimal"/>
        <Column Name="InterestRepayment" DataType="System.Decimal"/>
        <Column Name="TotalAmount" DataType="System.Decimal"/>
        <Column Name="DateApproved" DataType="System.DateTime"/>
        <Column Name="DisburseAmount" DataType="System.Decimal"/>
        <Column Name="LastRepayDate" DataType="System.DateTime"/>
        <Column Name="PaymentMode" DataType="System.String"/>
        <Column Name="DisburseDate" DataType="System.DateTime"/>
      </TableDataSource>
    </MsSqlDataConnection>
