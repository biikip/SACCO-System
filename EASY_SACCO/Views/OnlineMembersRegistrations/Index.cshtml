@model General

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<head>
    <style>
        .excel-button {
            background-color: #217346;
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

            .excel-button:hover {
                background-color: #1E5A34;
            }

        .custom-table {
            background-color: white;
            border-radius: 8px;
            box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2);
        }

            .custom-table th {
                background-color: #0f1230;
                color: white;
                text-align: center;
                padding: 12px;
            }

            .custom-table td {
                padding: 12px;
                font-size: 16px;
                color: #333; /* Darker text for better readability */
                font-weight: 500;
            }

        .edit-link {
            background-color: #007bff;
            color: white;
            padding: 8px 12px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
            display: inline-block;
            transition: 0.3s;
        }

            .edit-link:hover {
                background-color: #0056b3;
            }
    </style>
</head>

<div class="row bg-white shadow-sm p-0 mb-4">
    <div class="col-8">
        <div style="color:black;font-size:x-large;" class="text-capitalize">
            Members</div>
        <div style="color:black;">
            List of Members</div>
    </div>
    <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
        <a asp-action="Create" asp-controller="MembersRegistrations"  style="background:#0670ba;padding:4px;border-radius:8px;color:white"><i class="fa fa-eye" aria-hidden="true"></i> Add New Member
        </a>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="p-4 bg-white shadow-sm rounded">
        <table class="table table-striped table-bordered table-sm" style="color: black" id="myTable">
            <thead style="background-color: #0f1230; color: white">
                <tr>
                    <th>Full Name / Group Name</th>
                    <th>Member No</th>
                    <th>Phone No</th>
                    <th>Status</th>
                    <th>Group</th>
                    <th>ID No</th>
                    <th>Email</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>

                @if (Model.membersRegistrations.Count() != 0)
                {
                    @foreach (var item in Model.membersRegistrations)
                    {
                        @if (item.MemberType == "Individual")
                        {
                        var groupname = "n/a";
                        var group = Model.CIG_Croups.FirstOrDefault(k => k.Id.ToString() == item.strCIGGroupId);
                        if (group != null)
                        {
                            groupname = group.strName;
                        }
                        <tr>
                            <td><strong>@item.strOtherName @item.strSurName</strong></td>
                            <td>@item.strMemberNo</td>
                            <td>@item.strPhoneNo</td>
                            <td>@item.strActiveStatus</td>
                            <td>@groupname</td>
                            <td>@item.strIdNo</td>
                            <td>@item.strEmail</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.strId" class="edit-link">
                                    <i class="fa fa-pencil"></i> Edit
                                </a>
                            </td>
                            </tr>
                        }
                        else
                        {
                            var groupname = "n/a";
                            var group = Model.CIG_Croups.FirstOrDefault(k => k.Id.ToString() == item.strCIGGroupId);
                            if (group != null)
                            {
                                groupname = group.strName;
                            }
                            <tr>
                                <td><strong>@item.GroupName</strong></td>
                                <td>@item.strMemberNo</td>
                                <td>@item.strPhoneNo</td>
                                <td>@item.strActiveStatus</td>
                                <td>@groupname</td>
                                <td>@item.strIdNo</td>
                                <td>@item.strEmail</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.strId" class="edit-link">
                                        <i class="fa fa-pencil"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-danger">No Members Found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/DataTable/js/JavaScript.js" asp-append-version="true"></script>
    <script src="~/DataTable/js/JavaScript1.js"></script>
    <script src="~/DataTable/js/JavaScript2.js"></script>
    <script src="~/DataTable/js/JavaScript3.js"></script>
    <script src="~/DataTable/js/JavaScript4.js"></script>
    <script src="~/DataTable/js/JavaScript5.js"></script>
    <script src="~/DataTable/js/JavaScript6.js"></script>
    <script src="~/DataTable/js/JavaScript7.js"></script>
    <style>
        .dataTables_wrapper .dataTables_filter lebal[type="text"] {
            font-weight: bold;
        }
    </style>
    <script type="text/javascript">
        $(document).ready(function () {
            // Initialize DataTable with buttons
            var table = $('#myTable').DataTable({
                dom: 'Bf<"toolbar">tip',
                buttons: [
                    {
                        extend: 'excel',
                        text: '<strong style="color:black">Excel</strong>',
                        exportOptions: {
                            columns: ':not(.exclude)'
                        }
                    },
                    {
                        extend: 'pdf',
                        text: '<strong style="color:black">PDF</strong>',
                        exportOptions: {
                            columns: ':not(.exclude)'
                        }
                    }
                ],
                columnDefs: [
                    {
                        targets: [7], // Assuming action column is the 9th column (index 8)
                        visible: true,
                        className: 'exclude'
                    }
                ]
            });
        });
    </script>
}

