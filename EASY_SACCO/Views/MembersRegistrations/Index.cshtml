@model General

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<head>
    <style>
        .excel-button {
            background-color: #217346;
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

            .excel-button:hover {
                background-color: #1E5A34;
            }

        .custom-table {
            background-color: white;
            border-radius: 8px;
            box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2);
        }

            .custom-table th {
                background-color: #0f1230;
                color: white;
                text-align: center;
                padding: 12px;
            }

            .custom-table td {
                padding: 12px;
                font-size: 16px;
                color: #333; /* Darker text for better readability */
                font-weight: 500;
            }

        .edit-link {
            background-color: #007bff;
            color: white;
            padding: 8px 12px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
            display: inline-block;
            transition: 0.3s;
        }

            .edit-link:hover {
                background-color: #0056b3;
            }
    </style>
</head>

<div class="row bg-white shadow-sm p-0 mb-4">
    <div class="col-8">
        <div style="color:black;font-size:x-large;" class="text-capitalize">
            Members
        </div>
        <div style="color:black;">
            List of Members
        </div>
    </div>
    <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
            <a asp-action="Create" asp-controller="MembersRegistrations" style="background:#0670ba;padding:4px;border-radius:8px;color:white">
                <i class="fa fa-eye" aria-hidden="true"></i> Add New Member
            </a>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="p-4 bg-white shadow-sm rounded">
        <div style="overflow-x: auto; max-width: 100%;">
            <table class="table table-striped table-bordered table-sm" style="color: black; min-width: 1000px;" id="myTable">      
            <thead style="background-color: #0f1230; color: white">
                <tr>
                    <th>Full Name / Group Name</th>
                    <th>Member No</th>
                    <th>Phone No</th>
                    <th>Group</th>
                    <th>ID No</th>
                    <th>Email</th>
                    <th>Approval Status</th>
                    <th>Actions</th>
                    <th>View Statement</th> <!-- New Column -->
                </tr>
            </thead>
            <tbody>
                @if (Model.membersRegistrations.Count() != 0)
                {
                    @foreach (var item in Model.membersRegistrations)
                    {
                        var groupname = "n/a";
                        var group = Model.CIG_Croups.FirstOrDefault(k => k.Id.ToString() == item.strCIGGroupId);
                        if (group != null)
                        {
                            groupname = group.strName;
                        }
                        <tr>
                            <td><strong>@(item.MemberType == "Individual" ? $"{item.strOtherName} {item.strSurName}" : item.GroupName)</strong></td>
                            <td>@item.strMemberNo</td>
                            <td>@item.strPhoneNo</td>
                            <td>@item.GroupName</td>
                            <td>@item.strIdNo</td>
                            <td>@item.strEmail</td>
                            <td>
                                @if (!item.IsApproved)
                                {
                                    <span class="badge rounded-pill bg-primary px-3 py-1">
                                        <i class="fa fa-sync-alt"></i> Pending Approval
                                    </span>
                                }
                                else if (item.IsApproved && !item.HasPaidRegFee)
                                {
                                    <span class="badge rounded-pill bg-warning text-dark px-3 py-1">
                                        <i class="fa fa-star"></i> Pending Reg. Fee
                                    </span>
                                }
                                else if (item.IsApproved && item.HasPaidRegFee)
                                {
                                    <span class="badge rounded-pill bg-success px-3 py-1">
                                        <i class="fa fa-check-circle"></i> Active
                                    </span>
                                }
                            </td>

                                <td>
                                    <a asp-action="Edit" asp-controller="MembersRegistrations" asp-route-id="@(Convert.ToInt32(item.strId))">
                                        <i class="fa fa-pencil"></i> Edit
                                    </a> |
                                    <button type="button" class="btn btn-link text-danger p-0" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.strId">
                                        <i class="fa fa-trash"></i> Remove
                                    </button>
                                    <!-- Delete Confirmation Modal -->
                                    <div class="modal fade" id="deleteModal-@item.strId" tabindex="-1" aria-labelledby="deleteModalLabel-@item.strId" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content">
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title" id="deleteModalLabel-@item.strId">Confirm Delete</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body">
                                                    Are you sure you want to delete member <strong>@item.strMemberNo</strong>?
                                                </div>
                                                <div class="modal-footer">
                                                    <form asp-action="Delete" asp-controller="MembersRegistrations" asp-route-id="@item.strId" method="post">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                </td>


                            <td>
                                    <a asp-action="Getcontributions" asp-controller="MembersRegistrations" asp-route-id="@item.strMemberNo" class="d-flex align-items-center gap-1" style="white-space: nowrap;">
                                        <i class="fa fa-file-alt"></i> View Statement
                                    </a>


                                </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        </div>
       
        <!-- Approve Modal -->
        <div class="modal fade" id="approveModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title">Confirm Approval</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to approve this user?
                    </div>
                    <div class="modal-footer">
                        <form id="approveForm" method="post">
                            <input type="submit" class="btn btn-success" value="Yes, Approve" />
                        </form>
                        <input type="button" class="btn btn-secondary" value="Cancel" data-bs-dismiss="modal" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Reject Modal -->
        <div class="modal fade" id="rejectModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">Confirm Rejection</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to reject this user?
                    </div>
                    <div class="modal-footer">
                        <form id="rejectForm" method="post">
                            <input type="submit" class="btn btn-danger" value="Yes, Reject" />
                        </form>
                        <input type="button" class="btn btn-secondary" data-bs-dismiss="modal" value="Cancel" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {


    <script src="~/DataTable/js/JavaScript.js" asp-append-version="true"></script>
    <script src="~/DataTable/js/JavaScript1.js"></script>
    <script src="~/DataTable/js/JavaScript2.js"></script>
    <script src="~/DataTable/js/JavaScript3.js"></script>
    <script src="~/DataTable/js/JavaScript4.js"></script>
    <script src="~/DataTable/js/JavaScript5.js"></script>
    <script src="~/DataTable/js/JavaScript6.js"></script>
    <script src="~/DataTable/js/JavaScript7.js"></script>
    <style>
        .dataTables_wrapper .dataTables_filter label {
            font-weight: bold;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script type="text/javascript">
        function showApproveModal(event, id) {
            event.preventDefault();
            var form = document.getElementById('approveForm');
            form.action = '/MembersRegistrations/ApproveMember/' + id;
            var modal = new bootstrap.Modal(document.getElementById('approveModal'));
            modal.show();
        }

        function showRejectModal(event, id) {
            event.preventDefault();
            var form = document.getElementById('rejectForm');
            form.action = '/MembersRegistrations/RejectMember/' + id;
            var modal = new bootstrap.Modal(document.getElementById('rejectModal'));
            modal.show();
        }

                $(document).ready(function () {
            $('#myTable').DataTable({
                responsive: true,
                pageLength: 10,
                ordering: true,
                dom: 'Bf<"toolbar">tip',
                buttons: [
                    {
                        extend: 'excel',
                        text: '<strong style="color:black">Excel</strong>',
                        exportOptions: {
                            columns: [0, 1, 2, 3, 4, 5, 6] // exclude Actions column (index 7)
                        }
                    },
                    {
                        extend: 'pdf',
                        text: '<strong style="color:black">PDF</strong>',
                        exportOptions: {
                            columns: [0, 1, 2, 3, 4, 5, 6]
                        }
                    }
                ],
                columnDefs: [
                    {
                        targets: [7], // Action column index
                        className: 'exclude'
                    }
                ]
            });
        });
    </script>
}



