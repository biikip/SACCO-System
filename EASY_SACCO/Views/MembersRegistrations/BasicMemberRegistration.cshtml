<script type="text/javascript">
    $(document).ready(function () {
        $('#MemberType').change(function () {
            var memberType = $(this).val();
            if (memberType === 'Group / Corporate') {
                $('.group-section').show();
                $('.group-name-section').show();
                $('.surname-section, .othername-section, .dob-section, .gender-section').hide();
                $('#individualMessage').hide(); // Hide individual message
            } else if (memberType === 'Individual') {
                $('.group-section').hide();
                $('.group-name-section').hide();
                $('.surname-section, .othername-section, .dob-section, .gender-section').show();
                $('#individualMessage').show(); // Show individual message
            } else {
                $('.group-section').hide();
                $('.group-name-section').hide();
                $('.surname-section, .othername-section, .dob-section, .gender-section').show();
                $('#individualMessage').hide(); // Hide individual message
            }
        });
    });
    $('input[name="strPhoneNo"]').blur(function () {
        var phone = $(this).val();
        checkUnique('Phone', phone, $(this));
    });

    $('input[name="strIdNo"]').blur(function () {
        var id = $(this).val();
        checkUnique('ID', id, $(this));
    });

    $('input[name="strEmail"]').blur(function () {
        var email = $(this).val();
        checkUnique('Email', email, $(this));
    });

    function checkUnique(field, value, element) {
        if (value.trim() === '') return;

        $.get('/MembersRegistrations/CheckUnique', { field: field, value: value }, function (isValid) {
            if (!isValid) {
                $(element).addClass('is-invalid');
                if (field === 'Phone') {
                    $(element).next('.text-danger').text('Phone Number already exists.');
                } else if (field === 'ID') {
                    $(element).next('.text-danger').text('ID Number already exists.');
                } else if (field === 'Email') {
                    $(element).next('.text-danger').text('Email already exists.');
                }
            } else {
                $(element).removeClass('is-invalid');
                $(element).next('.text-danger').text('');
            }
        });
    }

    function countrychange() {
        // disable the state DropDownList
        var state = document.getElementById('state').ej2_instances[0];
        var city = document.getElementById('city').ej2_instances[0];
        var country = document.getElementById('country').ej2_instances[0];
        state.enabled = true;
        //frame the query based on selected value in country DropDownList.
        var tempQuery = new ej.data.Query().where('strCountyId', 'equal', country.value);
        // set the framed query based on selected value in country DropDownList.
        state.query = tempQuery;
        // set null value to state DropDownList text property
        state.text = null;
        //  bind the property changes to state DropDownList
        state.dataBind();
        // set null value to city DropDownList text property
        city.text = null;
        // disable the city DropDownList
        city.enabled = false;
        // bind the property changes to City DropDownList
        city.dataBind();
    }
    function statechange() {
        var city = document.getElementById('city').ej2_instances[0];
        var state = document.getElementById('state').ej2_instances[0];
        city.enabled = true;
        //Query the data source based on state DropDownList selected value
        var tempQuery = new ej.data.Query().where('strSubCountyId', 'equal', state.value);
        //set the framed query based on selected value in city DropDownList.
        city.query = tempQuery;
        //clear the existing selection
        city.text = null;
        //bind the property change to city DropDownList
        city.dataBind();

    }
