<style>
    #customers {
        font-family: Arial, Helvetica, sans-serif;
        border-collapse: collapse;
        width: 100%;
    }

        #customers td, #customers th {
            border: 1px solid #ddd;
            padding: 8px;
        }

        #customers tr:nth-child(even) {
            background-color: #f2f2f2;
        }

        #customers tr:hover {
            background-color: #4cff00;
        }

        #customers th {
            padding-top: 12px;
            padding-bottom: 12px;
            text-align: left;
            background-color: #dec3eb;
            color: white;
        }

    .divScroll {
        width: auto;
        height: 420px;
        overflow: auto;
    }
</style>
<section class="section">
    <div class="row">
        <div class="card">
            <div class="col-xs-12">
                <div class="normal-table-list mg-t-30">
                    <div class="row">
                        <div class="col-sm-3 col-xs-12">
                            <h3 class="card-title">Balance Sheet</h3>
                        </div>
                        <div class="col-sm-7 col-xs-12">
                        </div>
                    </div>

                    <form asp-action="Create">
                        <div class="row">
                            <div class="col-sm-4 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label">From Date</label>
                                    <input type="date" id="fromDate" class="form-control" />
                                </div>
                            </div>
                            <div class="col-sm-4 col-xs-12">
                                <div class="form-group">
                                    <label class="control-label">To Date</label>
                                    <input type="date" id="toDate" class="form-control" />
                                </div>
                            </div>
                            <div class="col-sm-4 col-xs-12">
                                @*<a id="endOfDay" class="btn btn-success">Intake End Of Day</a>*@
                            </div>
                        </div>
                    </form>

                    <div class="bsc-tbl-hvr table-border-style">
                        <div class="divScroll">
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>
                                                Gl Acc
                                            </th>
                                            <th>
                                                Acc Name
                                            </th>
                                            <th>
                                                Sh.
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody id="details">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</section>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script type="text/javascript">
        $(function () {
            let assets = new Array();
            let liabilities = new Array();
            let capitals = new Array();
            let profit = 0;

            $('#fromDate').on('change', function () {
                buildBalanceSheet();
            });

            $('#toDate').on('change', function () {
                buildBalanceSheet();
            });

            function buildBalanceSheet() {
                var fromDate = $("#fromDate").val();
                var toDate = $("#toDate").val();
                var filter = {
                    fromDate: fromDate,
                    toDate: toDate,
                };
                
                if (fromDate && toDate) {
                    $.ajax({
                        type: 'POST',
                        url: "balanceSheet",
                        contentType: 'application/json',
                        data: JSON.stringify(filter),
                        success: function (response) {
                            assets = response.assets ? response.assets : new Array();
                            liabilities = response.liabilities ? response.liabilities : new Array();
                            capitals = response.capitals ? response.capitals : new Array();
                            profit = response.profit ? response.profit : 0;
                            populateDetailsTable();
                        },
                        failure: function (response) {
                        }
                    }).then(function () {
                        // ...
                    });
                }
            }

            function populateDetailsTable() {
                let itemTableRows = new Array();
                var liability = 0;
                var capital = 0;
                var asset = 0;
                var dr = 0;
                var dramount = 0;
                var cramount = 0;
                var cr = 0;
                itemTableRows.push(`<tr>
                    <td colspan="6"><h3>Assets</h3></td>
                </tr>`);

                assets.forEach(j => {
                    j.TransDate = j.TransDate ? j.TransDate : "";
                    j.TransDate = new Date(j.TransDate).toLocaleDateString('en-GB');
                    dramount = j.Dr - j.Cr;
                    itemTableRows.push(`<tr>
                        <td>${j.GlAcc}</td>
                        <td>${j.AccName}</td>
                        <td>${dramount}</td>
                    </tr>`);
                    dr += j.Dr;
                    cr += j.Cr;
                });

                // itemTableRows.push(`<tr>
                //     <td colspan="4"><h3></h3></td>
                //     <td>${dr.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                //     <td>${cr.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                // </tr>`);

                asset = asset + (dr - cr);
                itemTableRows.push(`<tr>
                    <td colspan="5"><h3>Total Assets</h3></td>
                    <td>${asset.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                </tr>`);

                dr = 0;
                cr = 0;
                itemTableRows.push(`<tr>
                    <td colspan="6"><h3>Liabilities</h3></td>
                </tr>`);

                liabilities.forEach(j => {
                    j.TransDate = j.TransDate ? j.TransDate : "";
                    j.TransDate = new Date(j.TransDate).toLocaleDateString('en-GB');
                    cramount = j.Cr - j.Dr;
                    itemTableRows.push(`<tr>
                        <td>${j.GlAcc}</td>
                        <td>${j.AccName}</td>
                        <td>${cramount}</td>
                    </tr>`);
                    dr += j.Dr;
                    cr += j.Cr;
                    liability += cramount;
                });
                // itemTableRows.push(`<tr>
                //     <td colspan="4"><h3></h3></td>
                //     <td>${dr.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                //     <td>${cr.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                // </tr>`);
                
                itemTableRows.push(`<tr>
                    <td colspan="5"><h3>Total Liabilities</h3></td>
                    <td>${liability.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                </tr>`);

                dr = 0;
                cr = 0;
                itemTableRows.push(`<tr>
                    <td colspan="6"><h3></h3></td>
                </tr>`);

                capitals.forEach(j => {
                    j.TransDate = j.TransDate ? j.TransDate : "";
                    j.TransDate = new Date(j.TransDate).toLocaleDateString('en-GB');
                    itemTableRows.push(`<tr>
                        <td>${j.TransDate}</td>
                        <td>${j.GlAcc}</td>
                        <td>${j.AccName}</td>
                        <td>${j.TransDescript}</td>
                        <td>${j.Dr}</td>
                        <td>${j.Cr}</td>
                    </tr>`);
                    dr += j.Dr;
                    cr += j.Cr;
                });

                let lose = profit < 0 ? -profit : 0;
                profit = profit < 0 ? 0 : profit;
                let nprofit = profit - lose;

                // itemTableRows.push(`<tr>
                //         <td colspan="4"><h3>Net Profit</h3></td>
                //         <td>${nprofit.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                //     </tr>`);

                dr += lose;
                cr += profit;
                // itemTableRows.push(`<tr>
                //     <td colspan="4"><h3></h3></td>
                //     <td>${dr.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                //     <td>${cr.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                // </tr>`);

               // capital = capital + (cr - dr);
                // itemTableRows.push(`<tr>
                //     <td colspan="5"><h3>Total Capital</h3></td>
                //     <td>${capital.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                // </tr>`);

                var capatalLiability = capital + liability;
                // itemTableRows.push(`<tr>
                //     <td colspan="5"><h3>Capital And Liabilities</h3></td>
                //     <td>${capatalLiability.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                // </tr>`);

                var variance = asset - capatalLiability;
                itemTableRows.push(`<tr>
                    <td colspan="5"><h3>Variance</h3></td>
                    <td>${variance.toLocaleString('en-US', { maximumFractionDigits: 2 })}</td>
                </tr>`);

                $('#details').html(itemTableRows);
            }
        });
    </script>
}
