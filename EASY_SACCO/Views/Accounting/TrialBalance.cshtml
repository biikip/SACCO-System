@model TrialBalanceViewModel
@{
    ViewData["Title"] = "Trial Balance";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}
<div class="container mt-5 statement-container">
    <div class="button-group text-end mb-3">
        <div class="col-auto">
            <button type="button" class=" btn-primary btn-sm" onClick="printCertificate()">Print  <span class="fa fa-print"></span></button>
            <button type="button" class="btn-primary btn-sm" onclick="exportTableToExcel('statement-table')">
                <i class="fa fa-file-excel"></i> Export Excel
            </button>
            <a asp-action="BooksOfAccounts" asp-controller="Accounting" class=" btn-info btn-sm">Go Back</a>
        </div>
    </div>
    <div id="statement-table">
    <div class="report-header text-center">
        <h2>@Model.CompanyName</h2>
        <h2>Trial Balance Report</h2>
        <p>Period: @Model.StartDate.ToString("yyyy-MM-dd") to @Model.EndDate.ToString("yyyy-MM-dd")</p>
        <p>Generated On: @Model.GeneratedDate.ToString("yyyy-MM-dd HH:mm:ss")</p>
    </div>  
   
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Acc No</th>
                    <th>Account Name</th>
                    <th>Debit</th>
                    <th>Credit</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.TrialBalanceItems)
                {
                    <tr>
                        <td>@item.AccNo</td>
                        <td>@item.AccName</td>
                        <td>@(item.Debit > 0 ? item.Debit.ToString("N2") : "-")</td>
                        <td>@(item.Credit > 0 ? item.Credit.ToString("N2") : "-")</td>
                    </tr>
                }
                <tr class="total-row">
                    <td colspan="2"><strong>Total</strong></td>
                    <td><strong>@Model.TrialBalanceItems.Sum(x => x.Debit).ToString("N2")</strong></td>
                    <td><strong>@Model.TrialBalanceItems.Sum(x => x.Credit).ToString("N2")</strong></td>
                </tr>
            </tbody>
        </table>


    <div class="footer text-center mt-3">
        <p>Generated by SACCO System</p>
    </div>
</div>
</div>
<style>
    body {
        background-color: #f8f9fa;
    }

    .statement-container {
    background-color: #ffffff;
    padding: 15px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    max-width: 1000px; /* Restrict width */
    margin: auto;
}

.report-header h2 {
    font-size: 1.3rem;
    font-weight: bold;
    color: #333;
    margin-bottom: 5px;
}

.report-header p {
    font-size: 0.9rem;
    margin: 2px 0;
}

.button-group {
    text-align: right;
    margin-bottom: 8px;
}

.button-group .btn {
    font-size: 0.8rem;
    padding: 5px 8px;
    margin-right: 3px;
}

.table {
    font-size: 0.85rem;
        color: #212529;
        width: 100%;
    border-collapse: collapse;
}

.table th {
    font-size: 0.9rem;
    font-weight: bold;
    text-align: center;
    vertical-align: middle;
    background-color: #343a40;
    color: white;
    padding: 6px;
}

.table td {
    font-size: 0.85rem;
    padding: 5px;
    text-align: center;
    vertical-align: middle;
}

.table td:nth-child(3),
.table td:nth-child(4) {
    text-align: right;
}

.table-bordered th, .table-bordered td {
    border: 1px solid #dee2e6;
}

.total-row {
    font-weight: bold;
    background-color: #e9ecef;
}

.footer {
    font-size: 0.8rem;
    color: #666;
    margin-top: 10px;
}

@@media print {
    body {
        background: #fff !important;
    }

    .statement-container {
        box-shadow: none !important;
        width: 100% !important;
    }

    .button-group {
        display: none !important;
    }

    .table {
        width: 100% !important;
    }

    @@page {
        margin: 1cm;
    }
}
</style>

@section Scripts {
    <script>
        function exportTableToExcel(tableId) {
            var table = document.getElementById(tableId);
            var html = table.outerHTML;
            var url = 'data:application/vnd.ms-excel,' + encodeURIComponent(html);
            var link = document.createElement("a");
            link.href = url;
            link.download = 'TrialBalance.xls';
            link.click();
        }

        function printCertificate() {
            const printContents = document.getElementById('statement-table').innerHTML;
            const originalContents = document.body.innerHTML;
            document.body.innerHTML = printContents;
            window.print();
            document.body.innerHTML = originalContents;
        }
    </script>
}
