@model EASY_SACCO.ViewModels.AccountingVm.JournalFilter
@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@using Syncfusion.EJ2
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}
<head>
    <link href="~/Syncfussion/styles/material.css" rel="stylesheet" />
    <script src="~/Syncfussion/scripts/ej2.min.js"></script>
</head>
<div class="row" style="background-color:white;box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2)">
    <div class="col-8">
        <div style="margin:8px;padding:8px;text-align:left">
            <div style="color:gray;font-size:small;" class="text-capitalize">Gl Inquiry</div>
        </div>
    </div>
    <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
        </div>
    </div>
</div>
<div class="container-fluid">
    <div style="padding:8px;margin:8px;border-radius:16px;background-color:white;box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2)">

        <form asp-action="Create" asp-controller="Accounting" style="padding:30px">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="col-md-4">
                    <br />
                    <label><strong style="color:black">Account No</strong></label>
                    <div class="padding-top">
                        <ejs-dropdownlist id="glAcc" ejs-for="AccNo"
                                          allowFiltering="true"
                                          :filtering="glAcc"
                                          filterBarPlaceholder="Search Account"
                                          placeholder="Select Account"
                                          popupHeight="300px"
                                          dataSource="@ViewBag.glAccounts">
                            <e-dropdownlist-fields text="strAccountName" value="strAccountNo"></e-dropdownlist-fields>
                        </ejs-dropdownlist>
                    </div>
                </div>
                <div class="col-md-4">
                    <br />
                </div>
                <div class="col-md-4">
                    <br />
                    <label><strong style="color:black">Balance</strong></label>
                    <input id="balance" class="form-control" type="text" readonly />
                </div>
                <div class="col-md-4">
                    <br />
                    <label><strong style="color:black">Date From</strong></label>
                    <input id="fromDate" name="FromDate" class="form-control" type="date" />
                    <span asp-validation-for="FromDate" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <br />
                    <label><strong style="color:black">Date To</strong></label>
                    <input id="toDate" name="ToDate" class="form-control" type="date" />
                    <span asp-validation-for="ToDate" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <br />
                    <br />
                    <br />
                    <a id="save" class="btn-success btn-lg">Show</a>
                </div>
                <div class="col-md-12">
                    <div class="bsc-tbl-hvr table-border-style pt-3" style="color:black">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <tr style="background-color:#0f1230;color:white">
                                    <th>
                                        Trans Date
                                    </th>
                                    <th>
                                        Member No
                                    </th>
                                    <th>
                                        Document No
                                    </th>
                                    <th>
                                        Remarks
                                    </th>

                                    <th>
                                        Debits
                                    </th>
                                    <th>
                                        Credits
                                    </th>
                                    <th>
                                        Balance
                                    </th>
                                </tr>
                                <tbody id="details" style="color:black">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <br />

            </div>
            <br />
            <div class="col-md-3">
                <div class="row">
                    <br />

                </div>


            </div>

        </form>
    </div>
    <br />
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script type="text/javascript">

            $(function () {
                let journalDetails = new Array();
            var today = new Date();//.toISOString().split('T')[0];
            var date = new Date(), y = date.getFullYear(), m = date.getMonth();
            var firstDay = new Date(y, m, 2).toISOString().split('T')[0];
            var lastDay = new Date(y, m + 1, 1).toISOString().split('T')[0];
            $("#fromDate").val(firstDay);
            $("#toDate").val(lastDay);
                $('#myInput').on('keyup', function () {
                    $('#gl-setup').show();
                    var value = $(this).val().toLowerCase();
                    $("#glTable tr").filter(function() {
                      $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                    });
                });

                $('#accNo').on('keyup', function () {
                    var glAccounts = @Html.Raw(Json.Serialize(ViewBag.glAccounts));
                    var accNo = $("#accNo").val();
                    var glAccount = glAccounts.filter(p => p.AccNo === accNo);
                    if (glAccount[0]) {
                        $("#accName").val(glAccount[0].GlAccName);
                    }

                    buildJournalDetails();
                });

                $('#fromDate').on('change', function () {
                    buildJournalDetails();
                });

                $('#toDate').on('change', function () {
                    buildJournalDetails();
                });

            $('#save').on('click', function () {
                buildJournalDetails();
            });
                function buildJournalDetails() {
                var accNo = $("#glAcc").val();
                    var fromDate = $("#fromDate").val();
                    var toDate = $("#toDate").val();
                    debugger
                    var filter = {
                        accNo: accNo,
                        fromDate: fromDate,
                        toDate: toDate
                    };

                    if (accNo && fromDate && toDate) {
                        $.ajax({
                            type: 'POST',
                            url: "glInquiry",
                            contentType: 'application/json',
                            data: JSON.stringify(filter),
                            success: function (response) {
                                debugger
                               response = response ? response : {};
                               response.bookBalance = response.bookBalance ? response.bookBalance : 0;
                               $("#balance").val(response.bookBalance);
                               journalDetails = response.journals ? response.journals : new Array();
                               console.log("Journal details:", journalDetails); // 🔍 ADD THIS LINE
                               populateDetailsTable();
                              },

                            failure: function (response) {
                            }
                        }).then(function () {
                            // ...
                        });
                    }
                }

                function populateDetailsTable() {
                    let itemTableRows = new Array();
                        journalDetails.forEach(j => {
                            debugger
                            console.log(j); 
                            let ddate = j.transDate;
                            let balance = j.dr - j.cr;
                            let dd1 = new Date(ddate).toLocaleDateString();
                            itemTableRows.push(`<tr>
                            <td>${dd1}</td>
                            <td>${j.memberNo}</td>
                            <td>${j.documentNo}</td>
                            <td>${j.transDescript}</td>
                            <td>${j.dr}</td>
                            <td>${j.cr}</td>
                            <td>${j.bal}</td>
                            </tr>`);
                        });

                    $('#details').html(itemTableRows);
                }
            });
                    function glAcc(e) {
            var query = new ej.data.Query();
            query = (e.text !== '') ? query.where('strAccountName', 'startswith', e.text, true) : query;
            e.updateData(@Html.Raw(JsonConvert.SerializeObject(ViewBag.glAccounts)), query);
        }
            function getSelectedAcc(accNo) {
                accNo = `${accNo}`;
                $("#accNo").val(accNo);
                var glAccounts = @Html.Raw(Json.Serialize(ViewBag.glAccounts));
                var glAccount = glAccounts.filter(p => p.AccNo === accNo);
                if (glAccount[0]) {
                    $("#accName").val(glAccount[0].GlAccName);
                }
                $('#gl-setup').hide();
            }
    </script>
    <script>
        var glAccounts = @Html.Raw(JsonConvert.SerializeObject(ViewBag.glAccounts));

        function glAcc(e) {
            console.log('Searching:', e.text); // debug
            var query = new ej.data.Query();
            if (e.text !== '') {
                query = query.where('strAccountName', 'contains', e.text, true);
            }
            e.updateData(glAccounts, query);
        }
    </script>
}
