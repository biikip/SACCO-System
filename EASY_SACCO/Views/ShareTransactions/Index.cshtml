@model List<EASY_SACCO.Models.CustomerBalanceViewModel>
@{
    ViewData["Title"] = "Shares Transaction";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="row" style="background-color:white;box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2)">
    <div class="col-8">
        <div style="margin:8px;padding:8px;text-align:left">
            <div style="color:black;font-size:xx-large;" class="text-capitalize">Shares Transaction </div>
            <div style="color:gray;font-size:small;" class="text-capitalize">List of Shares Transaction</div>
        </div>
    </div>
    <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
            <a asp-action="Create" asp-controller="ShareTransactions" style="background:#0670ba;padding:4px;border-radius:8px;color:white"><i class="fa fa-plus" aria-hidden="true"></i> Add New Share Transaction </a>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div style="margin:8px;padding:8px;background-color:white">
        <form id="dateForm" asp-action="getsharestransaction" method="post">
            <div class="row">
                <div class="col-md-3">
                    <label>Date From</label>
                    <input type="date" class="form-control" id="startDate" name="StartDate" />
                </div>
                <div class="col-md-3">
                    <label>Date To</label>
                    <input type="date" class="form-control" id="endDate" name="EndDate" />
                </div>
                <div class="col-md-3">
                    <br /><br />
                    <button id="submitButton" type="button" class="btn-primary">Process</button>
                </div>
            </div>
        </form>

        <div style="margin:8px;padding:8px;background-color:white">
            <table class="table table-striped table-bordered table-sm" style="color:black" id="customerbal">
                <thead style="background-color:#0f1230;color:white">
                    <tr>
                        <th>Document No</th>
                        <th>Member No</th>
                        <th>Name</th>
                        <th>Amount</th>
                        <th>Credit Account No</th>
                        <th>Debit Account No</th>
                        <th>Account No</th>
                        <th>Transaction Date</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <script type="text/javascript">
           $(document).ready(function () {
        var table = $('#customerbal').DataTable({
            processing: true,
            serverSide: true,
            ajax: {
                url: '/ShareTransactions/GetDataTableData',
                type: 'GET',
                data: function (d) {
                    d.StartDate = $('#startDate').val();
                    d.EndDate = $('#endDate').val();
                }
            },
            columns: [
                { data: 'documentNumber' },
                { data: 'memberNo' },
                { data: 'memberName' },
                { data: 'amount' },
                { data: 'crAccNo' },
                { data: 'drAccNo' },
                { data: 'accountNo' },
                {
                    data: 'transDate',
                    render: function (data) {
                        if (data) {
                            return data.split('T')[0];   // show only the date
                        }
                        return '';
                    }
                }
                ]
            });

            $('#submitButton').click(function () {
                table.ajax.reload();  // Reload the table data with the updated filter
            });
        });
                $('#submitButton').click(function () {
            var formData = {
                StartDate: $('#startDate').val(),
                EndDate: $('#endDate').val()
            };

            console.log("Sending request with data:", formData);

            $.ajax({
                type: 'POST',
                url: '@Url.Action("GetSharesTransaction", "ShareTransactions")',  // Correct controller/action
                data: JSON.stringify(formData),
                contentType: 'application/json',
                success: function (data) {
                    console.log("Server Response:", data);
                    if (Array.isArray(data) && data.length > 0) {
                        populateIntake(data);
                    } else {
                        table.clear().draw();
                        console.warn("No transactions found.");
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Failed to post form data:', error);
                }
            });
        });


        function validateDate() {


            // Get the selected date from the date picker input
            var selectedDate = new Date(document.getElementById('startdate').value);
            // Get the current date
            var currentDate = new Date();

            // Check if the selected date is before the current date
            if (selectedDate > currentDate) {
                // If the selected date is in the past, show an alert
                toastr.error('The Selected Date exceed the current date.', { timeOut: 5000 });

                // Clear the date picker input
                document.getElementById('startdate').value = '';
            }
        }

        function updateMaxDate() {
            // Set the max attribute of the date input to the current date
            var currentDate = new Date().toISOString().split('T')[0];
            document.getElementById('startdate').setAttribute('max', currentDate);
        }

        // Set the default value of the date picker to the current date
        document.getElementById('startDate').valueAsDate = new Date();

        // Set the default value of the date picker to the current date
        document.getElementById('endDate').valueAsDate = new Date();

    </script>
}
