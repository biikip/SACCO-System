@using Microsoft.AspNetCore.Http;
@using Microsoft.AspNetCore.Http.Extensions;
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserType");
}

<style>
    .card {
        border: none;
        border-radius: 1rem;
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        .card .card-body {
            position: relative;
            overflow: hidden;
        }

    .text-muted {
        font-size: 0.9rem;
    }

    .btn-custom {
        background: #0d6efd;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 50px;
        transition: all 0.3s ease;
    }

        .btn-custom:hover {
            background: #0b5ed7;
            color: #fff;
        }

    .wave-svg {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 50px;
    }

    .modal-footer a {
        background: #dc3545;
        color: #fff !important;
        border: none;
        padding: 8px 16px;
        border-radius: 50px;
    }

        .modal-footer a:hover {
            background: #c82333;
            color: #fff !important;
        }

    .section-header {
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        color: #6c757d;
    }
</style>

<div class="container-fluid">
    <!-- Header -->
    <div class="row bg-white py-3 px-4 align-items-center border-bottom shadow-sm mb-4 rounded">
        <div class="col">
            <h2 class="text-capitalize text-dark font-weight-bold mb-0">Dashboard</h2>
        </div>
        <div class="col text-right">
            <span class="text-muted">@DateTime.UtcNow.AddHours(3).ToString("dddd, MMM dd yyyy")</span>
        </div>
    </div>

    <!-- Welcome Card -->
    <div class="row mb-4">
        <div class="col">
            <div class="card shadow-sm py-3 px-4 d-flex justify-content-between flex-row align-items-center">
                <div>
                    <h5 class="mb-1 text-dark">Welcome back,</h5>
                    <h4 class="font-weight-bold text-primary">@EASY_SACCO.Controllers.HomeController.Username</h4>
                </div>
                <div>
                    <a class="btn btn-custom" href="#" data-toggle="modal" data-target="#logoutModal">
                        <i class="fas fa-sign-out-alt mr-2"></i>Sign Out
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row">
        <!-- Members -->
        <div class="col-xl-3 col-md-6 mb-4">
