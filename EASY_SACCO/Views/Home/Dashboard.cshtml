                        <h4 class="font-weight-bold text-dark">@ViewBag.TotalMembers</h4>
                        <p class="text-muted small">Total Members</p>
                    </div>
                    <svg class="position-absolute bottom-0 start-0 w-100" style="height: 50px;" viewBox="0 0 1440 320">
                        <path fill="#0d6efd" fill-opacity="0.2" d="M0,256L48,240C96,224,192,192,288,197.3C384,203,480,245,576,234.7C672,224,768,160,864,133.3C960,107,1056,117,1152,149.3C1248,181,1344,235,1392,261.3L1440,288L1440,0L0,0Z"></path>
                    </svg>
                </div>
            </a>
        </div>
        <!-- Savings -->
        <div class="col-xl-3 col-md-6 mb-4">
            <a href="@Url.Action("SavingDetails", "Home")" style="text-decoration: none;">
                <div class="card shadow-sm h-100 border-0 position-relative overflow-hidden">
                    <div class="card-body">
                        <div class="text-xs font-weight-bold text-uppercase text-success mb-2">Savings</div>
                        <h4 class="font-weight-bold text-dark">@ViewBag.Savings</h4>
                        <p class="text-muted small">Current Savings</p>
                    </div>
                    <svg class="position-absolute bottom-0 start-0 w-100" style="height: 50px;" viewBox="0 0 1440 320">
                        <path fill="#198754" fill-opacity="0.2" d="M0,256L48,240C96,224,192,192,288,197.3C384,203,480,245,576,234.7C672,224,768,160,864,133.3C960,107,1056,117,1152,149.3C1248,181,1344,235,1392,261.3L1440,288L1440,0L0,0Z"></path>
                    </svg>
                </div>
            </a>
        </div>

        <!-- Registration Fees -->
        <div class="col-xl-3 col-md-6 mb-4">
            <a href="@Url.Action("RegistrationFeeDetails", "Home")" style="text-decoration: none;">
                <div class="card shadow-sm h-100 border-0 position-relative overflow-hidden">
                    <div class="card-body">
                        <div class="text-xs font-weight-bold text-uppercase text-info mb-2">Registration Fees</div>
                        <h4 class="font-weight-bold text-dark">@ViewBag.FEE</h4>
                        <p class="text-muted small">Total Collection</p>
                    </div>
                    <svg class="position-absolute bottom-0 start-0 w-100" style="height: 50px;" viewBox="0 0 1440 320">
                        <path fill="#0dcaf0" fill-opacity="0.2" d="M0,256L48,240C96,224,192,192,288,197.3C384,203,480,245,576,234.7C672,224,768,160,864,133.3C960,107,1056,117,1152,149.3C1248,181,1344,235,1392,261.3L1440,288L1440,0L0,0Z"></path>
                    </svg>
                </div>
            </a>
        </div>

        <!-- Management Fees -->
        <div class="col-xl-3 col-md-6 mb-4">
            <a href="@Url.Action("TotalShareCapitalDetails", "Home")" style="text-decoration: none;">
                <div class="card shadow-sm h-100 border-0 position-relative overflow-hidden">
                    <div class="card-body">
                        <div class="text-xs font-weight-bold text-uppercase text-warning mb-2">Total Shares</div>
                        <h4 class="font-weight-bold text-dark">@ViewBag.Capital</h4>
                        <p class="text-muted small">Total Payments</p>
                    </div>
                    <svg class="position-absolute bottom-0 start-0 w-100" style="height: 50px;" viewBox="0 0 1440 320">
                        <path fill="#ffc107" fill-opacity="0.2" d="M0,256L48,240C96,224,192,192,288,197.3C384,203,480,245,576,234.7C672,224,768,160,864,133.3C960,107,1056,117,1152,149.3C1248,181,1344,235,1392,261.3L1440,288L1440,0L0,0Z"></path>
                    </svg>
                </div>
            </a>
        </div>

    </div>
