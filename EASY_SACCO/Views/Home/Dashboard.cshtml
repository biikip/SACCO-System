    <!-- Chart Section -->
    <div class="row">
        <div class="col-xl-6 col-md-6 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="text-primary font-weight-bold mb-3">Membership</h5>
                    <canvas id="membershipChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-xl-6 col-md-6 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                        <h5 class="card-title">SACCO Financial Overview</h5>
                        <canvas id="saccoChart"></canvas>
                    </div>
            </div>
        </div>
    </div>
    <!-- Logout Modal-->
    <div class="modal fade" id="logoutModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
         aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content shadow-sm">
                <div class="modal-header">
                    <h5 class="modal-title">Ready to Leave?</h5>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <div class="modal-body">Select "Logout" below if you are ready to end your current session.</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary rounded-pill" type="button" data-dismiss="modal">Cancel</button>
                    <a asp-action="LogOut" asp-controller="Home">Logout</a>
                </div>
            </div>
        </div>
    </div>
</div>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .custom-container {
        max-width: 600px; /* Adjust width as needed */
        width: 100%;
    }</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    fetch('/Home/GetMonthlyRegistrations')
        .then(response => response.json())
        .then(data => {
            console.log("Chart Data:", data); // Debugging

            if (!Array.isArray(data) || data.length === 0) {
                console.warn("No membership data found!");
                return;
            }

            // Ensure data is correctly formatted
            const labels = data.map(d => d.month); // Use only month names
            const values = data.map(d => Number(d.count) || 0);

            // Destroy previous chart if exists
            if (window.myChart) {
                window.myChart.destroy();
            }

            // Create new Chart instance
            const ctx = document.getElementById('membershipChart').getContext('2d');
            window.myChart = new Chart(ctx, {
                type: 'line',  // Change from 'bar' to 'line'
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Members',
                        data: values,
                        backgroundColor: 'rgba(54, 162, 235, 0.2)', // Light blue fill
                        borderColor: 'rgba(54, 162, 235, 1)', // Blue line
                        borderWidth: 2,
                        pointRadius: 5,
                        pointBackgroundColor: 'blue',
                        fill: true, // Fill area under the line
                        tension: 0.4 // Smooth curves
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            suggestedMax: Math.max(...values) + 5 // Adjust max value dynamically
                        }
                    }
                }
            });
        })
        .catch(error => console.error("Error fetching chart data:", error));
        const ctx = document.getElementById('saccoChart').getContext('2d');
    const saccoChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Savings', 'Registration Fees', 'Share Capital'],
            datasets: [{
                label: 'Amount (KES)',
                data: [
               @ViewBag.Savingss,
               @ViewBag.Feess,
               @ViewBag.Capitals
                ],
                backgroundColor: [
                    'rgba(25, 135, 84, 0.7)',     // Green
                    'rgba(13, 202, 240, 0.7)',    // Blue
                    'rgba(255, 193, 7, 0.7)'      // Yellow
                ],
                borderColor: [
                    'rgba(25, 135, 84, 1)',
                    'rgba(13, 202, 240, 1)',
                    'rgba(255, 193, 7, 1)'
                ],
                borderWidth: 1
            }]
        },
        options: {
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function(value) {
                            return 'KES ' + value.toLocaleString();
                        }
                    }
                }
            },
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return 'KES ' + context.parsed.y.toLocaleString();
                        }
                    }
                }
            }
        }
    });

</script>