@using (Html.BeginForm("Login", "Home", FormMethod.Post, new { role = "form" }))
{
    <div class="container d-flex justify-content-center align-items-center min-vh-100" style="background-color: #f8f9fa;">
        <div class="row shadow-lg rounded-4 p-4" style="max-width: 900px; width: 100%; background-color: #ffffff;">

            <!-- Left Side (Welcome Section) -->
            <div class="col-md-6 d-flex flex-column align-items-center text-center p-4">
                <h2 class="fw-bold mb-3" style="color: #28A745;">Welcome Back!</h2>
                <p class="text-muted">Sign in to continue.</p>
                <img src="~/Icons/homepagelogo.png" class="img-fluid mb-3" style="max-height: 150px;">
            </div>

            <!-- Right Side (Login Form) -->
            <div class="col-md-6 p-4 rounded-3" style="background-color: #ffffff;">
                <h3 class="text-center mb-4" style="color: #28A745;">Login</h3>

                @Html.AntiForgeryToken()

                <!-- Username Input -->
                <div class="mb-3">
                    <label for="username" class="form-label fw-bold" style="color: #333; font-size: 16px;">User Name</label>
                    <input type="text" id="username" class="form-control border-success py-2" name="username" placeholder="Enter your Member Number" required>
                </div>

                <!-- Password Input -->
                <div class="mb-3">
                    <label for="password" class="form-label fw-bold" style="color: #333; font-size: 16px;">Password</label>
                    <input type="password" id="password" class="form-control border-success py-2" name="userPassword" placeholder="Enter your password" required>
                </div>
                <!-- CAPTCHA Input Row -->
                <div class="mb-3 d-flex align-items-center">
                    <label class="form-label fw-bold" style="color: #333; font-size: 16px;">Verification Code:</label>

                    <input type="text" name="CaptchaCode" class="form-control border-success w-25 me-2" required />

                    <!-- CAPTCHA Image -->
                    <img src="@Url.Action("GenerateCaptcha", "Home")" id="captchaImage" style="height: 40px;width:100px;" />

                    <!-- Bootstrap Icons CDN -->
                    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

                    <!-- Use Bootstrap refresh icon -->
                    <button type="button" onclick="refreshCaptcha()" class="btn btn-link p-0 ms-2" title="Refresh CAPTCHA">
                        <i class="bi bi-arrow-clockwise text-success" style="font-size: 1.2rem;"></i>
                    </button>

                </div>

                <!-- Remember Me & Forgot Password -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe">
                        <label class="form-check-label text-muted" for="rememberMe">Remember Me</label>
                    </div>
                    <a href="@Url.Action("ForgotPassword", "System_Users")" class="text-decoration-none fw-bold" style="color: #28A745;">Forgot Password?</a>
                </div>

                <!-- Login Button -->
                <button type="submit" class="btn w-100 text-white py-2" style="background-color: #28A745; font-size: 18px; font-weight: bold;">Login</button>

                <!-- Registration Link -->
                <div class="text-center mt-3">
                    <span class="text-muted">Don't have an account?</span>
                    <a href="@Url.Action("Register", "System_Users")" class="fw-bold" style="color: #28A745;">Register Here</a>
                </div>

                <!-- Error Messages -->
                <div class="mt-3">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                    @if (TempData["wrong_credentials"] != null)
                    {
                        <div class="alert alert-danger">@TempData["wrong_credentials"]</div>
                    }
                    @if (TempData["Not_Approoved"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Not_Approoved"]</div>
                    }
                    @if (TempData["Err"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["Err"]
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
}
<script>
    function refreshCaptcha() {
        const img = document.getElementById('captchaImage');
        img.src = '@Url.Action("GenerateCaptcha", "Home")' + '?' + new Date().getTime(); // force reload
    }
</script>
