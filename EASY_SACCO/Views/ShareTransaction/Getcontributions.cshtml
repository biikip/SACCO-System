@model List<EASY_SACCO.Models.Customer_Balance>

@{
    ViewData["Title"] = "Getcontributions";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}
<div class="row" style="background-color:white;box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2)">
    <div class="col-8">

        <div style="margin:8px;padding:8px;text-align:left">
            <div style="color:black;font-size:xx-large;" class="text-capitalize"> Contributions </div>
            <div style="color:gray;font-size:small;" class="text-capitalize">List of Contributions </div>
        </div>

    </div>
    <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
            <a asp-action="Shares_loansEnquiry" asp-controller="ShareTransaction" style="background:#0670ba;padding:4px;border-radius:8px;color:white"><i class="fa fa-eye" aria-hidden="true"></i> Back To Enquiry </a>
        </div>
    </div>
</div>

<div class="container-fluid">
   
    <partial name="_Search" />
    <div style="margin:8px;padding:8px;background-color:white">
        <table class="table   table-striped table-bordered  table-sm" style="color:black">
            <thead style="background-color:#0f1230;color:white">
                <tr>

                    <th>
                        Member No
                    </th>

                    <th>
                       Name
                    </th>
                    <th>
                       Description
                    </th>
                    <th>
                       Amount
                    </th>
                    <th>
                        Transaction Date
                    </th>
                 
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())

                {
                    @foreach (var item in Model)
                    {
                      

                        <tr>

                            <td>
                                @item.Memberno
                            </td>
                            <td>
                                @item.MemberName
                            </td>
                            <td>
                                @item.Transdescription
                            </td>
                           
                            <td>
                                @Math.Round(item.Amount,2)
                            </td>
                            <td>
                                @item.TransDate.ToShortDateString()
                            </td>
                 
                        </tr>
                     
                        
                    }
                }
                else
                {
                    <tr>
                        <td colspan="14" style="text-align:center;color:red">No Records  Found </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

