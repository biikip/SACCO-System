@model List<EASY_SACCO.Models.Customer_Balance>

@{
    ViewData["Title"] = "Shares Transaction";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="row" style="background-color:white;box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2)">
    <div class="col-8">

        <div style="margin:8px;padding:8px;text-align:left">
            <div style="color:black;font-size:xx-large;" class="text-capitalize">Shares Transaction </div>
            <div style="color:gray;font-size:small;" class="text-capitalize">List of  Shares Transaction</div>
        </div>

    </div>
    <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
            <a asp-action="Create" asp-controller="ShareTransactions" style="background:#0670ba;padding:4px;border-radius:8px;color:white"><i class="fa fa-plus" aria-hidden="true"></i> Add New ShareTransaction </a>
        </div>
    </div>
</div>

<div class="container-fluid">
<div style="margin:8px;padding:8px;background-color:white">

        <form id="dateForm" asp-action="getsharestransaction" method="post">
            <div class="row">
                <div class="col-md-3">
                    <label>Date From</label>
                    <input type="date" class="form-control" id="startDate" name="StartDate" />
                </div>
                <div class="col-md-3">
                    <label>Date To</label>
                    <input type="date" class="form-control" id="endDate" name="EndDate" />
                </div>
                <div class="col-md-3">
                    <br /><br />
                    <button id="submitButton" type="button" class="btn-primary">Process</button>

                </div>
            </div>
        </form>

          

 
                <div style="margin:8px;padding:8px;background-color:white">
                    <table class="table   table-striped table-bordered  table-sm" style="color:black " id="customerbal">
                        <thead style="background-color:#0f1230;color:white">

                            <tr>
                                <th>
                                    Document No
                                </th>
                                <th>
                                    Member No
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                     Amount
                                </th>
                               
                                <th>
                                    Credit Account No
                                </th>
                                <th>
                                    Debit Account No
                                </th>
                                <th>
                                    Account No
                                </th>
                                <th>
                                    Transaction Date
                                </th>
                            </tr>
                        </thead>
                        <tbody id="intakes">
                        </tbody>

                    </table>

                </div>
            </div>
        </div>
      

<br />
<br />
<br />
<br />
<div class="toolbar"></div>


