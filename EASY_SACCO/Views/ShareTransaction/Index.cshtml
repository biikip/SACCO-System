    <script type="text/javascript">
        
        $(document).ready(function () {
         

            var table = $('#customerbal').DataTable({
                dom: 'Bf<"toolbar">tip',
                buttons: [
                    {
                        extend: 'excel',
                        text: '<strong style="color:black">Excel</strong>',
                        exportOptions: {
                            columns: ':not(.exclude)'
                        }
                    },
                    {
                        extend: 'pdf',
                        text: '<strong style="color:black">PDF</strong>',
                        exportOptions: {
                            columns: ':not(.exclude)'
                        }
                    }
                ],
                columnDefs: [
                    {
                        targets: [7], // Assuming action column is the 9th column (index 8)
                        visible: true,
                        className: 'exclude'
                    }
                ]
            });

            $('#submitButton').click(function () {
                var formData = {
                    StartDate: $('#startDate').val(),
                    EndDate: $('#endDate').val()
                };

                var url = $('#dateForm').attr('action');

                $.ajax({
                    type: 'POST',
                    url: url,
                    data: JSON.stringify(formData),
                    contentType: 'application/json',
                    success: function (data) {
                        populateIntake(data);
                    },
                    error: function (xhr, status, error) {
                        console.error('Failed to post form data:', error);
                    }
                });
            });

            function populateIntake(intakes) {
                // Clear previous content before appending new rows
                table.clear().draw();

                intakes.forEach(i => {
                    let parsedDate = Date.parse(i.transDate);
                    if (!isNaN(parsedDate)) {
                        let dateObj = new Date(parsedDate);
                        let day = String(dateObj.getDate()).padStart(2, '0');
                        let month = String(dateObj.getMonth() + 1).padStart(2, '0');
                        let year = dateObj.getFullYear();
                        let formattedDate = `${day}/${month}/${year}`;

                        table.row.add([
                            i.documentnumber,
                            i.memberno,
                            i.memberName,
                            i.amount,
                            i.cRaccno,
                            i.dRaccno,
                            i.accountno,
                            formattedDate
                        ]).draw(false);
                    } else {
                        console.error('Invalid date:', i.transDate);
                    }
                });
            }
            
            populateIntake();
        });



