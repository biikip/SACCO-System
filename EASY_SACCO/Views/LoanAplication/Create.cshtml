            @section scripts {
                <script>

                    //Add Multiple list.
                    $("#addToList").click(function (e) {
                        e.preventDefault();

                        if ($.trim($("#Membernoids1").val()) == "" ||
                            $.trim($("#namess").val()) == "" ||
                            $.trim($("#currentshares").val()) == "" ||
                            $.trim($("#AmountI2").val()) == "") {
