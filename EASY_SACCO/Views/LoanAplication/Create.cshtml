<script type="text/javascript">
    $(function () {
        getSelectedDateIntakes();
        $('#membersconditions').click(function () {
            getSelectedDateIntakes();
        });
        $('#searchmembers').on('keyup', function () {
            getSelectedDateIntakes();
        });
        $('#Membernoids3').on('keyup', function () {
            getSelectedDateIntakes();
        });
        function getSelectedDateIntakes() {
            var memberrnos = $("#Membernoids3").val();
            var memberss = $("#searchmembers").val();
            var membersconditionss = $("#membersconditions").val();


            $.ajax({
                type: 'POST',
                url: "/LoanAplication/getmembers?memberrnos=" + memberrnos + "&memberss=" + memberss + "&membersconditionss=" + membersconditionss,
                contentType: 'application/json',
                success: function (response) {
            // Handle error returned from server
                 if (response.error) {
                alert(response.error); // or use your custom modal/notification
                return; // stop execution if there's an error
                }
                    populateIntake(response.members);
                    var memberno3 = response.membernos;
                    var namess = response.names;
                    var deposists = response.totaldeposit.toFixed(2);
                    var sharecapitals = response.totalsharecapital.toFixed(2);
                    //var maxloans = response.maxloan.toFixed(2);
                    var maturedshares = response.maturedshares.toFixed(2);
                    var loansbal = response.loanbal.toFixed(2);
                    var outstandingloans = response.outstandingloan;



                    $("#Membernoids3").val(memberno3);
