                        document.getElementById("repayperiod").value = "";
                        document.getElementById("loantypeid").value = "";
                        document.getElementById("maxloan").value = "";
                        document.getElementById("Maturedsharess").value = "";

                    }
                    // After Add A New Order In The List, If You Want, You Can Remove It.
                    $(document).on('click', 'a.deleteItem', function (e) {
                        e.preventDefault();
                        var $self = $(this);
                        if ($(this).attr('data-itemId') == "0") {
                            $(this).parents('tr').css("background-color", "#ff6347").fadeOut(800, function () {
                                $(this).remove();
                            });
                        }
                    });
                    //data with no commas
                    function numberWithnoCommas(x) {
                        return x.toString().replace(/\B(?=(\d{3})+(?!\d))/g, "");
                    }
                    //After Click Save Button Pass All Data View To Controller For Save Database
                    function saveOrder(data) {


                        return $.ajax({
                            type: 'POST',
                            url: "/LoanAplication/SaveOrder",
                            contentType: 'application/json; charset=utf-8',
                            data: JSON.stringify(data),
                            success: function (result) {
                                debugger

                                if (result.error != null) {
                                    toastr.error('The Loan has reached the maximum guarantorship!', { timeOut: 5000 })

                                }
                                else {
                                    toastr.success('Records Saved Successfully!!!', { timeOut: 5000 });

                                    clearItemss();
                                }


                                clearItem();
                                $("#detailsTable tbody tr").remove();


                                //  alert(result);
                                // location.reload();
                            },
                            error: function () {

                                // toastr.error('Error Something went wrong,Please try again!', { timeOut: 5000 })
                            }
                        });
                    }
                    //Collect Multiple Order List For Pass To Controller
                    $("#saveOrder").click(function (e) {

                        e.preventDefault();
                        //clearItem1();


                        var detailsArr = [];
                        detailsArr.length = 0;


                        $.each($("#detailsTable tbody tr"), function () {
                            var detail = {
                                MemberNo: $(this).find('td:eq(0)').html(),
                                FullNames: $(this).find('td:eq(1)').html(),
                                AmountDeposit: $(this).find('td:eq(2)').html(),
                                AmountGuaranteed: $(this).find('td:eq(3)').html(),

                            };
                            detailsArr.push(detail);
                        });

                        var data = {
                            loanguars: detailsArr,
                            memberNo: $("#Membernoids3").val(),
                            Deposit: Math.trunc($("#Deposit").val().replace(",", "")),
                            shareCapital: Math.trunc($("#Capital").val().replace(",", "")),
                            outstandingLoan: $("#Outstandingloans").val(),
                            loanBalance: $("#loanbal").val(),
                            loanNo: $("#Loannoid").val(),
                            appliedAmount: $("#AmountI").val(),
                            applicationDate: $("#applicationdate").val(),
                            repaymentPeriod: $("#repayperiod").val(),
                            loanCode: $("#loancodeid").val(),
                            interestRate: $("#interestrateid").val(),
                            repaymentMethod: $("#repaymethod").val(),

                        };

                        console.log(data);

                        // Check if memberNo is null, if null, override with a value
                        if (!data.memberNo) {
                            toastr.error('Member No Cannot be empty!', { timeOut: 5000 });
                            return;
                        }
                        // Check if appliedAmount is null, if null, override with a value
                        if (!data.appliedAmount) {
                            toastr.error('Loan Amount Cannot be empty!', { timeOut: 5000 });
                            return;
                        }
                        // Check if loanCode is null, if null, override with a value
                        if (!data.loanCode) {
                            toastr.error('Loan Type Cannot be empty!', { timeOut: 5000 });
                            return;
                        }



                        $.when(saveOrder(data)).then(function (response) {
                            console.log(response);


                        }).fail(function (err) {
                            console.log(err);
                        });

                    });


                </script>
            }


