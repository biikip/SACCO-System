                            return;
                        }



                        // if ($("#households").val() == "" ||$("#genders").val() == "" || $("#highesteducationlevel").val() == "" || $("#SNO").val() == "" || $("#User").val() == "" || $("#Branch").val() == "" || $("#Cooperative").val() == "") return;
                        let MemberNo = document.getElementById("Membernoids1").value;
                        let FullNames = document.getElementById("namess").value;
                        let AmountDeposits = document.getElementById("currentshares").value.replace(",", "");
                        let AmountGuaranteed = document.getElementById("AmountI2").value;
                        // let LoanNo = document.getElementById("Loannoid").value;


                        // detailsTableBody = $("#detailsTable tbody");

                        // var productItem = '<tr><td>' + MemberNo + '</td><td>' + FullNames + '</td><td>' + AmountDeposits + '</td><td>' + AmountGuaranteed + '</td><td><a data-itemId="0" href="#" class="deleteItem">Remove</a></td></tr>';
                        // detailsTableBody.append(productItem);
                        // Check if the MemberNo already exists in the table
                        let existingRecords = $("#detailsTable tbody tr").filter(function () {
                            return $(this).find('td:eq(0)').text() === MemberNo;
                        });

                        // If record already exists, do not append
                        if (existingRecords.length > 0) {
                            toastr.error("Record with Member No " + MemberNo + " already exists.", { timeOut: 5000 })
                            clearItem();
                            return false; // Prevent further execution
                        }

                        // Append the record if it doesn't already exist
                        detailsTableBody = $("#detailsTable tbody");
                        var productItem = '<tr><td>' + MemberNo + '</td><td>' + FullNames + '</td><td>' + AmountDeposits + '</td><td>' + AmountGuaranteed + '</td><td><a data-itemId="0" href="#" class="deleteItem">Remove</a></td></tr>';
                        detailsTableBody.append(productItem);

                        clearItem();
                        return true; // Record appended successfully


                    });
                    //After Add A New Order In The List, Clear Clean The Form For Add More Order.
                    function clearItem() {
                        document.getElementById("Membernoids1").value = "";
                        document.getElementById("namess").value = "";
                        document.getElementById("currentshares").value = "";
                        document.getElementById("AmountI2").value = "";


                    }
                    //After Add A New Order In The List, Clear Clean The Form For Add More records.
                    function clearItemss() {

                        document.getElementById("Membernoids3").value = "";
                        document.getElementById("AmountI").value = "";
                        document.getElementById("Deposit").value = "";
                        document.getElementById("Capital").value = "";
                        document.getElementById("Outstandingloans").value = "";
                        document.getElementById("loanbal").value = "";
                        document.getElementById("Loannoid").value = "";

