    function validateDate() {
        // Show overlay, loader, and message


        showOverlay();
        showLoader();
        showMessage("Please wait while we are processing your request...");

        // Simulate an asynchronous request (replace with actual request)
        setTimeout(function () {
            // Hide overlay, loader, and message when the processing is completed
            hideOverlay();
            hideLoader();
            hideMessage();
        }, 5000); // Change 5000 to the actual time it takes to complete your request




        // Get the selected date from the date picker input
        var selectedDate = new Date(document.getElementById('applicationdate').value);
        // Get the current date
        var currentDate = new Date();

        // Check if the selected date is before the current date
        if (selectedDate > currentDate) {
            // If the selected date is in the past, show an alert
            toastr.error('Application date can not exceed the current date.', { timeOut: 5000 });

            // Clear the date picker input
            document.getElementById('applicationdate').value = '';
        }
    }

    function updateMaxDate() {
        // Set the max attribute of the date input to the current date
        var currentDate = new Date().toISOString().split('T')[0];
        document.getElementById('applicationdate').setAttribute('max', currentDate);
    }

    // Set the default value of the date picker to the current date
    document.getElementById('applicationdate').valueAsDate = new Date();


