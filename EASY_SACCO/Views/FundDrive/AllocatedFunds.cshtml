@model List<EASY_SACCO.Models.FundDriveAllocationViewModel>

@{
    ViewData["Title"] = "Allocated Funds";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="row bg-white shadow-sm p-0 mb-4">
    <div class="col-8">
        <div style="color:black;font-size:x-large;" class="text-capitalize">
            Allocated Funds
        </div>
        <div style="color:black;">
            List of Allocated Funds
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="p-4 bg-white shadow-sm rounded">

        <table class="table table-striped table-bordered table-sm" style="color: black; min-width: 1000px;" id="myTable">
            <thead style="background-color: #0f1230; color: white">
                <tr>
                    <th>Project Name</th>
                    <th>Member No</th>
                    <th>Member Name</th>
                    <th>Contribution Amount</th>
                    <th>Ownership %</th>
                    <th>Allocation Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var allocation in Model)
                {
                    <tr>
                        <td>@allocation.Project.ProjectName</td>
                        <td>@allocation.MemberNo</td>
                        <td>@allocation.MemberName</td>
                        <td>@allocation.ContributionAmount.ToString("N2")</td>
                        <td>@allocation.OwnershipPercentage.ToString("N2")%</td>
                        <td>@allocation.AllocationDate.ToString("yyyy-MM-dd")</td>
                    </tr>

                }
            </tbody>
        </table>
    </div>
</div>
