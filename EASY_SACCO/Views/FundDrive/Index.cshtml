@model IEnumerable<Project>

@{
    ViewData["Title"] = "Fund Drive Allocation";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="container-fluid">
    <h2>Fund Drive Allocation</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="p-4 bg-white shadow-sm rounded">
        <table class="table table-striped table-bordered table-sm" style="color: black; min-width: 700px;">
            <thead style="background-color: #0f1230; color: white">
                <tr>
                    <th>Project Name</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model)
                {
                    <tr>
                        <td>@project.ProjectName</td>
                        <td>@(project.FundDriveAllocations.Any() ? "Funds Allocated" : "No Funds Yet")</td>
                        <td>
                            <div class="col-auto">
                            <a asp-controller="FundDrive" asp-action="AllocateFunds" asp-route-projectId="@project.Id" class="btn btn-primary">
                                Allocate Funds
                            </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
