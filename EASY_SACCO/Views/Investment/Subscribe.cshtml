@model Project
@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@using Syncfusion.EJ2
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Subscribe to " + Model.ProjectName;
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}
<head>
    <link href="~/Syncfussion/styles/material.css" rel="stylesheet" />
    <script src="~/Syncfussion/scripts/ej2.min.js"></script>
    <style>
        .header-space {
            margin-top: 0;
            padding-top: 0;
        }

        .e-ddl.e-input-group input.e-input::placeholder {
            font-size: 16px; /* Increase or decrease as needed */
            color: darkgrey; /* Set to a more visible color */
            opacity: 1; /* Ensure full opacity for better visibility */
        }

        .container {
            margin-top: 3px; /* or adjust to your preferred spacing */
        }
    </style>
</head>

<div class="row bg-white shadow-sm p-0 mb-4">
    <div class="col-md-8">
        <h2>Subscribe to @Model.ProjectName</h2>
    </div>
        <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
        <a asp-action="Index" asp-controller="Investment" style="background:#0670ba;padding:4px;border-radius:8px;color:white"><i class="fa fa-eye" aria-hidden="true"></i>Go Back</a>
    </div>
    </div>
</div>

<div class="container-fluid">
    <div style="padding:8px;margin:8px;border-radius:16px;background-color:white;box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2)">

        <form asp-action="Subscribe" method="post">
            <input type="hidden" name="projectId" value="@Model.Id" />

            <div class="form-group">
                <label>Member No</label>
                <input type="text" name="MemberNo" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Contribution Amount</label>
                <input type="number" name="amount" class="form-control" required />
            </div>

            <input type="submit" class="btn btn-success" value="Contribute"/>
        </form>
</div>
</div>
