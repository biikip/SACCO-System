@model General

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="row" style="background-color:white;box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2)">
    <div class="col-8">

        <div style="margin:8px;padding:8px;text-align:left">
            <div style="color:black;font-size:xx-large;" class="text-capitalize"> AccountSetupGLs </div>
            <div style="color:gray;font-size:small;" class="text-capitalize">List of  AccountSetupGLs</div>
        </div>

    </div>
    <div class="col-4">
        <div style="margin:8px;padding:8px;text-align:end">
            <a asp-action="Create" asp-controller="AccountSetupGLs" style="background:#0670ba;padding:4px;border-radius:8px;color:white"><i class="fa fa-plus" aria-hidden="true"></i> Add AccountSetupGLs </a>
        </div>
    </div>
</div>
<div class="container-fluid">
    <partial name="_Search" />
    <div style="margin:8px;padding:8px;background-color:white">
        <table class="table   table-striped table-bordered  table-sm" style="color:black">
            <thead style="background-color:#0f1230;color:white">
                <tr>
                    <th>
                        Account No
                    </th>
                    <th>
                        Account Name
                    </th>
                    <th>
                        Account Type
                    </th>
                    <th>
                        Account Group
                    </th>
                    <th>
                        Account Category
                    </th>
                    <th>
                        Company Name
                    </th>
                    <th>
                        Normal Balance
                    </th>
                    <th colspan="2">Action</th>
                </tr>
            </thead>
            <tbody id="myUL">
                @if (Model.accountSetupGLs.Count() != 0)
                {
                    @foreach (var item in Model.accountSetupGLs)
                    {
                        var accountype = "n/a";
                        var accountGroup = "n/a";
                        var Categotry = "n/a";
                        var Company = "n/a";
                        var Normalbal = "n/a";



                        var accountypee = Model.accountTypes.FirstOrDefault(k => k.strAccountType.ToString() == item.strAccountType);
                        if (accountypee != null)
                        {
                            accountype = accountypee.strAccountType;
                        }

                        var accountgroup = Model.accountGroups.FirstOrDefault(k => k.strAccoutGroup.ToString() == item.strAccountGroup);
                        if (accountgroup != null)
                        {
                            accountGroup = accountgroup.strAccoutGroup;
                        }
                        var categoryy = Model.accountCategories.FirstOrDefault(k => k.strAcCategory.ToString() == item.strAccountCategory);
                        if (categoryy != null)
                        {
                            Categotry = categoryy.strAcCategory;
                        }
                        var companycodee = Model.co_Operatives.FirstOrDefault(k => k.strCompanyCode == item.strCompanyCode);
                        

                        if (companycodee != null)
                        {
                            Company = companycodee.strCompanyName;
                        }

                        var Normalbalance = Model.normalBalances.FirstOrDefault(k => k.strId.ToString() == item.strNormalBal);

                        Normalbal = item.strNormalBal;

                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.strAccountNo)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.strAccountName)
                    </td>
                    <td>
                        @accountype
                    </td>
                    <td>
                        @accountGroup
                    </td>


                    <td>
                        @Categotry
                    </td>



                            <td>
                                @Company
                            </td>



                    <td>
                                @Normalbal
                    </td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@item.strId"><i class="fa fa-pencil" aria-hidden="true"></i> <span>Edit</span> </a>
                    </td>
                    <td>
                        <a asp-action="Delete" data-toggle="modal" data-target="#_@item.strId" style="color:red" asp-route-id="@item.strId"><i class="fa fa-trash" aria-hidden="true"></i> <span>Remove</span> </a>
                    </td>
                </tr>

                        <!-- Modal -->
                        <div id="_@item.strId" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false">
                            <div class="modal-dialog">

                                <!-- Modal content-->
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <div style="font-size:large;font-weight:bold" class="modal-title text-danger">
                                            <i class="fa fa-trash" aria-hidden="true"></i> Remove Account
                                        </div>

                                    </div>
                                    <div class="modal-body">
                                        <div style="font-size:large;font-weight:bold;text-align:center" class="modal-title">@item.strAccountName</div>

                                        <div class="alert alert-danger">Hey you are about to remove this Account.Are you sure you want to continue??</div>
                                    </div>
                                    <form asp-action="Delete">
                                        <input type="hidden" name="id" value="@item.strId" />
                                        <div class="modal-footer">
                                            <div class=" btn-success btn-sm" data-dismiss="modal">Cancel</div>
                                            <input type="submit" id="completebutton" value="REMOVE ACCOUNT " class=" btn-danger btn-sm" />

                                        </div>
                                    </form>

                                </div>

                            </div>
                        </div>
                    }


                }
                else
                {
                    <tr>
                        <td colspan="14" style="text-align:center;color:red">No Agents/Refference  Found </td>

                    </tr>
                }

        </table>
    </div>
</div>