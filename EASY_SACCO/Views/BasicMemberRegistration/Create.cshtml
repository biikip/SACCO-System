<div class="container-fluid">
    <div class="p-4 bg-white shadow-sm rounded">

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger"><strong>Error!</strong> @TempData["ErrorMessage"]</div>
        }

        <form asp-action="Create" asp-controller="BasicMemberRegistration" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Section Title -->
            <div style="  background-color: #f3f3f3;color:#8b8b8b;margin-bottom: 8px;padding:8px;margin-top:8px;">
                <strong style="color:black">Personal Information</strong>
            </div>

            <!-- Personal Info -->
            <div class="row g-4">
                <!-- Member Type -->
                @*                 <div class="col-md-3">
                    <label class="control-label">Member Type</label>
                    <select asp-for="MemberType" class="form-control"
                            dataSource="@ViewBag.strCIGGroupId">
                        <option value="" class="form-control">Select Member Type</option>
                        <option value="Individual">Individual</option>
                        <option value="Group/Corporate">Group / Corporate</option>
                    </select>
                    <span asp-validation-for="MemberType" class="text-danger" />
                </div> *@

                <!-- Group Name -->
                @*                 <div class="col-md-6 group-name-section" style="display: none;">
                    <label class="form-label">Group Name</label>
                    <input asp-for="GroupName" class="form-control form-control-sm" />
                    <span asp-validation-for="GroupName" class="text-danger small"></span>
                </div> *@

                <!-- Surname -->
                <div class="col-md-3 surname-section">
                    <label class="form-label">Surname</label>
                    <input asp-for="SurName" class="form-control form-control-sm" />
                    <span asp-validation-for="SurName" class="text-danger small"></span>
                </div>

                <!-- Other Name -->
                <div class="col-md-3 othername-section">
                    <label class="form-label">Other Name</label>
                    <input asp-for="OtherNames" class="form-control form-control-sm" />
                    <span asp-validation-for="OtherNames" class="text-danger small"></span>
                </div>
                <!-- ID No -->
                <div class="col-md-3">
                    <label class="form-label">ID No / Cert No</label>
                    <input asp-for="IDNO" class="form-control form-control-sm" required />
                    <span asp-validation-for="IDNO" class="text-danger small"></span>
                </div>

                <!-- Phone -->
                <div class="col-md-3">
                    <label class="form-label">Phone Number</label>
                    <input asp-for="PhoneNo" class="form-control form-control-sm" />
                    <span asp-validation-for="PhoneNo" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Recipient Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div id="individualMessage" class="alert alert-info" style="display: none;">
                <strong>Individual Registration:</strong> Requires a fee of Ksh 1,500, a passport photo, KRA PIN, and National ID.
            </div>

            <!-- Group Section -->
            <div class="group-section mt-4" style="display: none;">
                <div class="alert alert-info">
                    <strong>Group Registration Fee:</strong> Ksh 2,500 is required. Please upload a valid group certificate and fill in the officials' details below.
                </div>
            </div>

            <!-- Submit -->
            <div class="d-flex justify-content-left mt-2">
                <input type="submit" value="Send Registration Link" class="btn btn-primary" style="background-color:#0670ba;width:10%">
            </div>
        </form>
    </div>
</div>



<script type="text/javascript">
    $(document).ready(function () {
        $('#MemberType').change(function () {
            var memberType = $(this).val();
            if (memberType === 'Group / Corporate') {
                $('.group-section').show();
                $('.group-name-section').show();
                $('.surname-section, .othername-section, .dob-section, .gender-section').hide();
                $('#individualMessage').hide(); // Hide individual message
            } else if (memberType === 'Individual') {
                $('.group-section').hide();
                $('.group-name-section').hide();
                $('.surname-section, .othername-section, .dob-section, .gender-section').show();
                $('#individualMessage').show(); // Show individual message
            } else {
                $('.group-section').hide();
                $('.group-name-section').hide();
                $('.surname-section, .othername-section, .dob-section, .gender-section').show();
                $('#individualMessage').hide(); // Hide individual message
            }
        });
    });
    $('input[name="strPhoneNo"]').blur(function () {
        var phone = $(this).val();
        checkUnique('Phone', phone, $(this));
    });

    $('input[name="strIdNo"]').blur(function () {
        var id = $(this).val();
        checkUnique('ID', id, $(this));
    });

    $('input[name="strEmail"]').blur(function () {
        var email = $(this).val();
        checkUnique('Email', email, $(this));
    });

    function checkUnique(field, value, element) {
        if (value.trim() === '') return;

        $.get('/BasicMemberRegistration/CheckUnique', { field: field, value: value }, function (isValid) {
            if (!isValid) {
                $(element).addClass('is-invalid');
                if (field === 'Phone') {
                    $(element).next('.text-danger').text('Phone Number already exists.');
                } else if (field === 'ID') {
                    $(element).next('.text-danger').text('ID Number already exists.');
                } else if (field === 'Email') {
                    $(element).next('.text-danger').text('Email already exists.');
                }
            } else {
                $(element).removeClass('is-invalid');
                $(element).next('.text-danger').text('');
            }
        });
    }

    
        $('input[type=text]').each(function () {
            var req = $(this).attr('data-val-required');
            if (undefined != req) {
                var label = $('label[for="' + $(this).attr('strIdNo') + '"]');
                var text = label.text();
                if (text.length > 0) {
                    label.append('<span style="color:red"> *</span>');
                }
            }
        });
</script>




