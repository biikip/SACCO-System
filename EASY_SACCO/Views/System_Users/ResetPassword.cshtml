@model ResetPasswordViewModel
@using Syncfusion.EJ2
@using Newtonsoft.Json

@{
    ViewBag.Title = "Reset Password";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<head>
    <link href="~/Syncfussion/styles/material.css" rel="stylesheet" />
    <script src="~/Syncfussion/scripts/ej2.min.js"></script>
</head>

<div class="row" style="background-color:white;box-shadow: 0 4px 8px rgba(0,0,0,0.2);">
    <div class="col-8">
        <div class="p-3 text-start">
            <h2 class="text-dark">Forgot Password</h2>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="p-4 m-3 rounded-3 shadow-sm bg-white">
        <form asp-action="ResetPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Hidden fields from reset link -->
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <!-- New Password -->
            <div class="form-group">
                <label asp-for="NewPassword"></label>
                <input asp-for="NewPassword" class="form-control" required />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Reset Password</button>
        </form>

        </div>
        </div>